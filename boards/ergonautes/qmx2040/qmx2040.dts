/dts-v1/;

#include <raspberrypi/rpi_pico/rp2040.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,flash-controller = &ssi;
        zephyr,code-partition = &code_partition;
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <8>;
        rows = <10>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7)  RC(5,7) RC(5,6) RC(5,5) RC(5,4) RC(5,3) RC(5,2) RC(5,1) RC(5,0)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7)  RC(6,7) RC(6,6) RC(6,5) RC(6,4) RC(6,3) RC(6,2) RC(6,1) RC(6,0)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7)  RC(7,7) RC(7,6) RC(7,5) RC(7,4) RC(7,3) RC(7,2) RC(7,1) RC(7,0)
RC(3,0)         RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)                  RC(8,6) RC(8,5) RC(8,4) RC(8,3) RC(8,2)
RC(4,0)                 RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7)  RC(9,7) RC(9,6) RC(9,5) RC(9,4) RC(9,3)
        >;
    };

    kscan_composite: kscan_composite {
        compatible = "zmk,kscan-composite";
        rows = <10>;
        columns = <8>;

        left {
            kscan = <&kscan_left>;
        };

        right {
            kscan = <&kscan_right>;
            row-offset = <5>;
        };
    };

    kscan_left: kscan_left {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        row-gpios
            = <&rp2040_gpio 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Numbers
            , <&rp2040_gpio 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Top
            , <&rp2040_gpio  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Home
            , <&rp2040_gpio  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Bottom
            , <&rp2040_gpio  0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Thumb
        ;

        col-gpios
            = <&rp2040_gpio  1 GPIO_ACTIVE_HIGH>  // Bépo
            , <&rp2040_gpio  2 GPIO_ACTIVE_HIGH>  // Outer
            , <&rp2040_gpio  3 GPIO_ACTIVE_HIGH>  // Pinky
            , <&rp2040_gpio  4 GPIO_ACTIVE_HIGH>  // Ring
            , <&rp2040_gpio  5 GPIO_ACTIVE_HIGH>  // Middle
            , <&rp2040_gpio  6 GPIO_ACTIVE_HIGH>  // Index
            , <&rp2040_gpio  7 GPIO_ACTIVE_HIGH>  // Inner
            , <&rp2040_gpio 12 GPIO_ACTIVE_HIGH>  //  Tmx
        ;
    };

    kscan_right: kscan_right {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        row-gpios
            = <&io_exp_gpio  4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Numbers
            , <&io_exp_gpio  5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Top
            , <&io_exp_gpio  6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Home
            , <&io_exp_gpio  7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Bottom
            , <&io_exp_gpio 16 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // Thumb
        ;

        col-gpios
            = <&io_exp_gpio 15 GPIO_ACTIVE_HIGH>  // Bépo
            , <&io_exp_gpio 14 GPIO_ACTIVE_HIGH>  // Outer
            , <&io_exp_gpio 13 GPIO_ACTIVE_HIGH>  // Pinky
            , <&io_exp_gpio 12 GPIO_ACTIVE_HIGH>  // Ring
            , <&io_exp_gpio 11 GPIO_ACTIVE_HIGH>  // Middle
            , <&io_exp_gpio 10 GPIO_ACTIVE_HIGH>  // Index
            , <&io_exp_gpio  9 GPIO_ACTIVE_HIGH>  // Inner
            , <&io_exp_gpio  8 GPIO_ACTIVE_HIGH>  // Tmx
        ;
    };

    //                                     w   h      x      y     rot rx ry
    #define KEY(x, y) &key_physical_attrs 100 100 (x*100) (y*100)  0  0  0

    physical_layout0: physical_layout_0 { // First physical layout, use different naming for other layouts
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan_composite>; // Label of the kscan node, optional if all layouts use the same
        transform = <&default_transform>; // Label of the matrix transform for this layout
        keys
            = <KEY(0,  0.5)>
            , <KEY(1,  0.5)>
            , <KEY(2,  0.0)>
            , <KEY(3,  0.0)>
            , <KEY(4,  0.0)>
            , <KEY(5,  0.0)>
            , <KEY(6,  0.0)>
            , <KEY(7,  0.5)>

            , <KEY(8,  0.5)>
            , <KEY(9,  0.0)>
            , <KEY(10, 0.0)>
            , <KEY(11, 0.0)>
            , <KEY(12, 0.0)>
            , <KEY(13, 0.0)>
            , <KEY(14, 0.5)>
            , <KEY(15, 0.5)>

            , <KEY(0,  1.5)>
            , <KEY(1,  1.5)>
            , <KEY(2,  1.0)>
            , <KEY(3,  1.0)>
            , <KEY(4,  1.0)>
            , <KEY(5,  1.0)>
            , <KEY(6,  1.0)>
            , <KEY(7,  1.5)>

            , <KEY(8,  1.5)>
            , <KEY(9,  1.0)>
            , <KEY(10, 1.0)>
            , <KEY(11, 1.0)>
            , <KEY(12, 1.0)>
            , <KEY(13, 1.0)>
            , <KEY(14, 1.5)>
            , <KEY(15, 1.5)>

            , <KEY(0,  2.5)>
            , <KEY(1,  2.5)>
            , <KEY(2,  2.0)>
            , <KEY(3,  2.0)>
            , <KEY(4,  2.0)>
            , <KEY(5,  2.0)>
            , <KEY(6,  2.0)>
            , <KEY(7,  2.5)>

            , <KEY(8,  2.5)>
            , <KEY(9,  2.0)>
            , <KEY(10, 2.0)>
            , <KEY(11, 2.0)>
            , <KEY(12, 2.0)>
            , <KEY(13, 2.0)>
            , <KEY(14, 2.5)>
            , <KEY(15, 2.5)>

            , <KEY(0,  3.5)>
            , <KEY(2,  3.0)>
            , <KEY(3,  3.0)>
            , <KEY(4,  3.0)>
            , <KEY(5,  3.0)>
            , <KEY(6,  3.0)>

            , <KEY(9,  3.0)>
            , <KEY(10, 3.0)>
            , <KEY(11, 3.0)>
            , <KEY(12, 3.0)>
            , <KEY(13, 3.0)>

            , <KEY(0,  4.5)>
            , <KEY(3,  4.0)>
            , <KEY(4,  4.0)>
            , <KEY(5,  4.0)>
            , <KEY(6,  4.0)>
            , <KEY(7,  4.0)>

            , <KEY(8,  4.0)>
            , <KEY(9,  4.0)>
            , <KEY(10, 4.0)>
            , <KEY(11, 4.0)>
            , <KEY(12, 4.0)>
    };
};

rp2040_gpio: &gpio0 {
    status = "okay";
};

&pinctrl {
    i2c0_custom: i2c0_custom {
        group1 {
            pinmux = <I2C0_SCL_P21>, <I2C0_SDA_P20>;
            input-enable;
            input-schmitt-enable;
        };
    };
};

&i2c0 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;
    pinctrl-0 = <&i2c0_custom>;
    pinctrl-names = "default";

    io_exp_gpio: pcal6524@23 {
        compatible = "nxp,pcal6524";
        status = "okay";
        ngpios = <24>;
        #gpio-cells = <2>;
        gpio-controller;
        reg = <0x23>;
    };
};

&timer {
    status = "okay";
};

&rtc {
    clocks = <&clocks RPI_PICO_CLKID_CLK_RTC>;
    status = "okay";
};

&vreg {
    regulator-always-on;
    regulator-allowed-modes = <REGULATOR_RPI_PICO_MODE_NORMAL>;
};

zephyr_udc0: &usbd {
    status = "okay";
};

&flash0 {
    // Flex 25.xx: W25Q128JV onboard flash, 128M-bit memory (16MB).
    // Flex 26.01: W25Q16JVUX onboard flash, 16M-bit memory (2MB).
    // 2MB is more than enough, so let's use that for all Flex versions.
    reg = <0x10000000 DT_SIZE_M(2)>;

    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        // Reserved memory for the second-stage bootloader
        second_stage_bootloader: partition@0 {
            reg = <0x00000000 0x100>;
            read-only;
        };

        // Usable flash. Starts at 0x100, after the bootloader. The partition
        // size is 2MB minus:
        // - 0x100 bytes taken by the bootloader
        // - 0x20000 bytes (= 128 kB) taken by storage
        code_partition: partition@100 {
            reg = <0x100 (DT_SIZE_M(2) - 0x100 - DT_SIZE_K(128))>;
            read-only;
        };

        // Extra storage needed to store extra tweaks done using ZMK-Studio
        storage_partition: partition@1e0000 {
            reg = <0x1e0000 DT_SIZE_K(128)>;
        };
    };
};

&xosc {
    // Ensure the 12MHz oscillator has enough time to stabilize properly.
    // Required by Flex 25.xx, should be useless with Flex 26.01.
    startup-delay-multiplier = <64>;
};
