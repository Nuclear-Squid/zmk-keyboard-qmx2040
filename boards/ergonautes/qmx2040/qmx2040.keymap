#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>


/ {
  keymap {
    compatible = "zmk,keymap";

    base_layer: base_layer {
      display-name = "Base";
      bindings = <
        &kp N1 &kp GRAVE &kp N1 &kp N2 &kp N3 &kp N4 &kp N5 &kp N6       &kp N1 &kp N6 &kp N7 &kp N8    &kp N9  &kp N0   &kp MINUS &kp EQUAL
        &kp N2 &kp TAB   &kp Q  &kp W  &kp E  &kp R  &kp T  &kp N7       &kp N2 &kp Y  &kp U  &kp I     &kp O   &kp P    &kp LBKT  &kp RBKT
        &kp N3 &kp NUBS  &kp A  &kp S  &kp D  &kp F  &kp G  &kp N8       &kp N3 &kp H  &kp J  &kp K     &kp L   &kp SEMI &kp SQT   &kp BSLH
        &kp N4           &kp Z  &kp X  &kp C  &kp V  &kp B                      &kp N  &kp M  &kp COMMA &kp DOT &kp FSLH
        &kp N5                  &kp N1 &kp N2 &kp N3 &kp N4 &kp N5       &kp N6 &kp N7 &kp N8 &kp N9 &kp N0
      >;
    };
  };
};
